import pandas as pd

try:
    df = pd.read_excel('c:\\projects\\DOCS\\dsr_consolidation\\All Jobs (2).xlsx')
    print("Columns:", [c for c in df.columns if 'hawb' in c.lower() or 'job' in c.lower() or 'in bond' in c.lower()])
    
    # Let's find columns representing Job No and HAWB
    hawb_col = [c for c in df.columns if 'hawb' in c.lower()][0]
    job_col = [c for c in df.columns if 'job' in c.lower()][0]
    
    # Try to find exactly what HAWB looks like for SEZ-T where there might not be a clean In Bond Job No
    print("\nSample Data (Job No, HAWB, Parent Job):")
    cols_to_show = [job_col, hawb_col]
    if 'In Bond Job No' in df.columns:
        cols_to_show.append('In Bond Job No')
    elif 'In Bond Job' in df.columns:
        cols_to_show.append('In Bond Job')
    
    for i, row in df[cols_to_show].head(30).iterrows():
        print(f"Job: {row[job_col]} | HAWB: {row[hawb_col]} | Parent: {row.get('In Bond Job No', 'N/A')}")
        
    # Also print unique patterns in HAWB
    import re
    print("\nSample HAWB values that contain numbers:")
    for v in df[hawb_col].dropna().unique()[:30]:
        if any(char.isdigit() for char in str(v)):
            print(v)
            
except Exception as e:
    print("Error:", e)
