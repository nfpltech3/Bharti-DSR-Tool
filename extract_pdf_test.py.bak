import pdfplumber
import sys

pdf_path = r"c:\projects\DOCS\dsr_consolidation\Import CheckList-IR5330725-26-13-FEB-2026_08_05_PM.pdf"

try:
    with pdfplumber.open(pdf_path) as pdf:
        for i, page in enumerate(pdf.pages):
            print(f"--- PAGE {i+1} ---")
            print(page.extract_text())
            print("\n")
except Exception as e:
    print(f"Error reading PDF: {e}")
