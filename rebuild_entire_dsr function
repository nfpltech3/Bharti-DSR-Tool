void Rebuild_Entire_DSR()
{
	// WARNING: This assumes you have already deleted all rows in BHARTI_DSR!
	// STEP 1: IMPORT ALL INBOND & HOME PRE-ALERTS
	inbond_prealerts = Pre_Alert[Importer.Importer == "BHARTI AIRTEL LIMITED" || Importer.Importer == "BHARTI HEXACOM LIMITED" && BE_Type == "SEZ-Z" || BE_Type == "In-Bond" || BE_Type == "Home"];
	info "Found " + inbond_prealerts.count() + " Inbond/Home Pre-Alerts to import...";
	count_inbond = 0;
	for each  p in inbond_prealerts
	{
		job_no = ifnull(p.Job_No,0).toString();
		if(job_no == "0")
		{
			job_no = "";
		}
		be_type = ifnull(p.BE_Type,"").toString();
		// Determine Statuses
		initial_ftwz_status = if(be_type == "Home","Normal Shipment","FTA Pending");
		initial_current_status = "";
		if(be_type == "Home" && ifnull(p.Dispatch_Date,"").toString() != "")
		{
			initial_ftwz_status = "Normal Cleared";
			status_text = "DISPATCHED ON DTD. " + p.Dispatch_Date;
			if(ifnull(p.Vehicle_No,"").toString() != "")
			{
				status_text = status_text + " // VEHICLE NO. " + p.Vehicle_No;
			}
			initial_current_status = status_text;
		}
		// Create Master DSR Row only if it doesn't already exist
		existing = Bharti_DSR[Inbond_Job_Lookup == p.ID];
		if(existing.count() == 0)
		{
			if(initial_current_status != "")
			{
				insert into Bharti_DSR
				[
					Added_User=zoho.loginuser
					Inbond_Job_No=job_no
					Inbond_Job_Lookup=p.ID
					FTWZ_Status=initial_ftwz_status
					Current_Status=initial_current_status
				]
			}
			else
			{
				insert into Bharti_DSR
				[
					Added_User=zoho.loginuser
					Inbond_Job_No=job_no
					Inbond_Job_Lookup=p.ID
					FTWZ_Status=initial_ftwz_status
				]
			}
			count_inbond = count_inbond + 1;
		}
	}
	info "Created " + count_inbond + " new DSR Rows for Inbond/Home.";
	// STEP 2: IMPORT ALL EXBOND (SEZ-T) PRE-ALERTS
	exbond_prealerts = Pre_Alert[Importer.Importer == "BHARTI AIRTEL LIMITED" || Importer.Importer == "BHARTI HEXACOM LIMITED" && BE_Type == "SEZ-T"];
	info "Found " + exbond_prealerts.count() + " Exbond Pre-Alerts to link...";
	count_exbond = 0;
	for each  ex in exbond_prealerts
	{
		job_no = ifnull(ex.Job_No,0).toString();
		if(job_no == "0")
		{
			job_no = "";
		}
		parent_job_no = ifnull(ex.In_Bond_Job_No.Job_No,0).toString();
		// Use the Pre-Alert ID to find the newly created Inbond row! This works even without a Job No.
		parent_id = -1;
		if(ex.In_Bond_Job_No != null)
		{
			parent_id = ex.In_Bond_Job_No.ID;
		}
		// LEGACY FALLBACK: If Lookup is completely blank, try extracting Parent Job No from HAWB field
		if(parent_id == -1 && parent_job_no == "0")
		{
			legacy_hawb = ifnull(ex.HAWB_HBL,"").toString().trim();
			// If HAWB is purely a number (like 53416), that's our legacy Parent Job Number!
			if(legacy_hawb != "" && legacy_hawb.isNumber())
			{
				parent_job_no = legacy_hawb;
			}
		}
		// Try finding by ID first
		master_rows = Bharti_DSR[Inbond_Job_Lookup == parent_id];
		// Fallback to Job Number
		if(master_rows.count() == 0 && parent_job_no != "" && parent_job_no != "0")
		{
			master_rows = Bharti_DSR[Inbond_Job_No == parent_job_no];
		}
		if(master_rows.count() > 0)
		{
			for each  m in master_rows
			{
				m.Exbond_Job_Lookup=ex.ID;
				if(job_no != "")
				{
					m.Exbond_Job_No=job_no;
				}
				if(ifnull(ex.Dispatch_Date,"").toString() != "")
				{
					m.FTWZ_Status="FTA Cleared";
					status_text = "DISPATCHED ON DTD. " + ex.Dispatch_Date;
					if(ifnull(ex.Vehicle_No,"").toString() != "")
					{
						status_text = status_text + " // VEHICLE NO. " + ex.Vehicle_No;
					}
					m.Current_Status=status_text;
				}
				count_exbond = count_exbond + 1;
			}
		}
		else
		{
			info "WARNING: Skipped unlinked Exbond row for Job: " + job_no + ". Could not find Inbond parent mathematically.";
		}
	}
	info "Linked " + count_exbond + " Exbond records into the DSR.";
	// STEP 3: LINK ALL ERP RECORDS
	erp_records = All_shipment_data[Importer == "BHARTI AIRTEL LIMITED" || Importer == "BHARTI HEXACOM LIMITED"];
	info "Found " + erp_records.count() + " ERP Records to link...";
	count_erp = 0;
	for each  erp in erp_records
	{
		erp_job = ifnull(erp.Job_No.Job_No,0).toString();
		erp_type = ifnull(erp.Type_Of_B_E,"").toString();
		if(erp_job != "" && erp_job != "0")
		{
			if(erp_type == "SEZ-Z" || erp_type == "In-Bond" || erp_type == "Home")
			{
				dsr_rows = Bharti_DSR[Inbond_Job_No == erp_job];
				for each  row in dsr_rows
				{
					row.Inbond_BE_Lookup=erp.ID;
					count_erp = count_erp + 1;
				}
			}
			else if(erp_type == "SEZ-T")
			{
				dsr_rows = Bharti_DSR[Exbond_Job_No == erp_job];
				for each  row in dsr_rows
				{
					row.Exbond_BE_Lookup=erp.ID;
					count_erp = count_erp + 1;
				}
			}
		}
	}
	info "Linked " + count_erp + " ERP Records to the DSR.";
	info "FULLY REBUILT MASTER DSR!";
}